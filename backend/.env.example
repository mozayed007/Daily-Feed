# Daily Feed - Environment Configuration

# App Settings
APP_NAME="Daily Feed"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY="your-secret-key-here-change-in-production"

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL="sqlite+aiosqlite:///data/dailyfeed.db"

# LLM Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Alternative: OpenAI (optional)
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-3.5-turbo

# Alternative: Anthropic (optional)
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Alternative: Google Gemini (optional)
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Alternative: Fireworks AI (optional)
# FIREWORKS_API_KEY=your-fireworks-key
# FIREWORKS_MODEL=accounts/fireworks/routers/kimi-k2p6-turbo
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Agent Capabilities (provider-adaptive: native when supported, else local fallback)
ENABLE_WEB_SEARCH=true
ENABLE_URL_FETCH=true

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Redis (for Celery, optional)
REDIS_URL=redis://localhost:6379/0

# Scheduler
SCHEDULER_ENABLED=true
DIGEST_HOUR=8
DIGEST_MINUTE=0

# Feed Settings
MAX_ARTICLES_PER_SOURCE=15
SUMMARY_MAX_LENGTH=500
CRITIC_MIN_SCORE=7
