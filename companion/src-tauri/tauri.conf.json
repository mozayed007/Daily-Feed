{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daily Jarvis",
  "version": "0.1.0",
  "identifier": "com.dailyfeed.jarvis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Daily Jarvis",
        "width": 400,
        "height": 80,
        "minWidth": 320,
        "minHeight": 64,
        "maxWidth": 480,
        "maxHeight": 720,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "transparent": true,
        "focus": false,
        "center": false,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    },
    "trayIcon": {
      "id": "tray-default",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "store": {},
    "global-shortcut": {},
    "shell": {
      "open": true
    }
  }
}
